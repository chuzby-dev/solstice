# --- Server ---
PORT=4000
DATABASE_PATH=./data/trading-bot.sqlite

# --- Solana RPC (read-only in this phase: wallet balance lookups only, never signs) ---
# Devnet is used for wallet connect / balance display. A public devnet RPC is fine for
# this low-volume, read-only use case; swap in Helius/QuickNode/Triton before any real use.
SOLANA_DEVNET_RPC_URL=https://api.devnet.solana.com

# Used only by the "Whale/Wallet Copy-Trading" strategy to read a watched wallet's
# public transaction history (read-only, never signs). The public mainnet-beta
# endpoint is tightly rate-limited and will frequently fail getParsedTransaction calls;
# swap in Helius/QuickNode/Triton for whale-copy to work reliably.
SOLANA_MAINNET_RPC_URL=https://api.mainnet-beta.solana.com

# --- Market data (read-only, no API key required) ---
# Devnet has no real swap liquidity, so paper trading intentionally uses REAL mainnet
# prices against a VIRTUAL ledger. No funds are at risk from this.
# Uses Pyth Network's public Hermes API (the on-chain price oracle used throughout
# Solana DeFi) — no key needed, and unlike CoinGecko's free tier it isn't shared-IP
# rate-limited, so it can be polled quickly enough to feel as live as a wallet's price
# display. Jupiter's Price API and CoinGecko were tried first; see docs/ARCHITECTURE.md
# for why they were dropped if you want to switch to a Jupiter/Birdeye key instead.
PRICE_API_URL=https://hermes.pyth.network/v2/updates/price/latest
PRICE_POLL_INTERVAL_MS=2000

# Comma-separated list of token mint addresses the price feed/strategies are allowed to track.
# Defaults to SOL and USDC.
TOKEN_ALLOWLIST=So11111111111111111111111111111111111111,EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# --- Simulated trading costs (applied to EVERY paper trade, not a real charge) ---
# Estimated real Solana/Jupiter round-trip costs, so paper P&L doesn't look better than
# real trading would. See config.ts `estimateTradeFeeUsd` for how these combine, and
# docs/ARCHITECTURE.md for the reasoning. Calibrate these if you have better real-world
# numbers (e.g. from Jupiter quotes or your own priority-fee history).
SOLANA_TX_FEE_USD=0.0005
PRIORITY_FEE_USD=0.005
SWAP_FEE_BPS=10
SLIPPAGE_BUFFER_BPS=5

# --- Backtesting (packages/backend/scripts/backtest.ts) ---
# Historical OHLCV for the backtest engine only — never used by the live paper-trading
# path. Free tier at https://birdeye.so. See docs/ARCHITECTURE.md "Backtesting" for how
# it's used and cached.
# BIRDEYE_API_KEY=

# --- Future phases (not used yet, do not fill in real secrets) ---
# HOT_WALLET_KEYSTORE_PATH=
# HOT_WALLET_KEYSTORE_PASSPHRASE=
# HELIUS_API_KEY=
# TELEGRAM_BOT_TOKEN=
# DISCORD_WEBHOOK_URL=
